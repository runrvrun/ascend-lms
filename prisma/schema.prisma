generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()::text"))
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  status        UserStatus @default(ACTIVE)

  //employee data
  division     Division @default(MSD)
  title        JobTitle @default(ANALYST)
  officeId     String?

  accounts       Account[]
  sessions       Session[]
  roles          UserRole[]
  cohorts        CohortUser[]
  enrollments    PathwayEnrollment[]
  approvalsGiven PathwayEnrollment[] @relation("Approver")
  requestsMade   PathwayEnrollment[] @relation("Requester")
  courseProgress    CourseProgress[]
  contentProgresses ContentProgress[]
  points            UserPoint[]
  managers       UserManager[]       @relation("UserManagers")
  managedUsers   UserManager[]       @relation("ManagedUsers")
  office         Office?             @relation(fields: [officeId], references: [id])
  comments          Comment[]        @relation("CommentAuthor")
  replyMentions     Comment[]        @relation("CommentReplyTo")
  notifications     Notification[]
  assignmentSubmissions AssignmentSubmission[]
  gradedSubmissions     AssignmentSubmission[] @relation("AssignmentGrader")
  trainerCourses        CourseTrainer[]
  smeTopics             TopicSME[]
  courseFeedbacks       CourseFeedback[]
  growthPlans           GrowthPlan[]
  confirmedGrowthPlans  GrowthPlan[]     @relation("GrowthPlanConfirmer")

  password              String?
  activationToken       String?
  activationTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum Division {
  MSD
  DXD
  ISD
  OXD
  SCD
  SSD
  FIN
  OPD
  HDOPD
  IA
  EO
  PID
  Contractor
}

enum JobTitle {
  ANALYST
  ASSOCIATE
  MANAGER
  DIRECTOR
  PARTNER
  MANAGING_PARTNER
}

model Office {
  id   String @id @default(dbgenerated("gen_random_uuid()::text"))
  name String @unique

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()::text"))
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  ext_expires_in    Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()::text"))
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}

model UserRole {
  id String @id @default(dbgenerated("gen_random_uuid()::text"))

  userId String
  role   Role

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, role]) // prevent duplicate roles
}

enum Role {
  ADMIN
  MANAGER
  TRAINER
  SME
}

model UserManager {
  userId    String
  managerId String

  user    User @relation("UserManagers", fields: [userId], references: [id], onDelete: Cascade)
  manager User @relation("ManagedUsers", fields: [managerId], references: [id], onDelete: Cascade)

  @@id([userId, managerId])
}

model Cohort {
  id   String @id @default(dbgenerated("gen_random_uuid()::text"))
  name String @unique

  users       CohortUser[]
  pathways    CohortPathway[]
  enrollments PathwayEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model CohortUser {
  id String @id @default(dbgenerated("gen_random_uuid()::text"))

  cohortId String
  userId   String

  cohort Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cohortId, userId])
  @@index([cohortId])
  @@index([userId])
}

model CohortPathway {
  id String @id @default(dbgenerated("gen_random_uuid()::text"))

  cohortId  String
  pathwayId String

  cohort  Cohort  @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  pathway Pathway @relation(fields: [pathwayId], references: [id], onDelete: Cascade)

  @@unique([cohortId, pathwayId])
}

model Pathway {
  id                String        @id @default(dbgenerated("gen_random_uuid()::text"))
  name              String        @unique
  description       String?
  requiresApproval  Boolean       @default(false)
  tags              String[]      @default([])
  status            PublishStatus @default(PUBLISHED)

  courses            PathwayCourse[]
  cohortPathways     CohortPathway[]
  pathwayEnrollments PathwayEnrollment[]
  courseProgresses   CourseProgress[]
  contentProgresses  ContentProgress[]
  comments              Comment[]
  notifications         Notification[]
  assignmentSubmissions AssignmentSubmission[]
  courseFeedbacks       CourseFeedback[]
  growthPlans           GrowthPlan[]

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt DateTime?
}

enum PublishStatus {
  DRAFT
  PUBLISHED
}

model Course {
  id              String        @id @default(dbgenerated("gen_random_uuid()::text"))
  name            String        @unique
  description     String?
  status          PublishStatus @default(PUBLISHED)
  feedbackEnabled Boolean       @default(true)
  topicId         String?
  test       Test?
  assignment Assignment?

  topic            Topic?          @relation(fields: [topicId], references: [id])
  contents         Content[]
  pathways         PathwayCourse[]
  courseProgresses CourseProgress[]
  trainers         CourseTrainer[]
  feedbacks        CourseFeedback[]

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt DateTime?
}

model Topic {
  id        String     @id @default(dbgenerated("gen_random_uuid()::text"))
  name      String     @unique
  courses   Course[]
  smes      TopicSME[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model TopicSME {
  topicId String
  userId  String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([topicId, userId])
}

model CourseFeedback {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text"))
  userId    String
  courseId  String
  pathwayId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id])
  pathway Pathway @relation(fields: [pathwayId], references: [id])

  @@unique([userId, courseId, pathwayId])
}

model CourseTrainer {
  id       String @id @default(dbgenerated("gen_random_uuid()::text"))
  courseId String
  userId   String

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([courseId, userId])
  @@index([userId])
}

model PathwayCourse {
  id String @id @default(dbgenerated("gen_random_uuid()::text"))

  pathwayId String
  courseId  String

  order  Int // enforce sequence
  points Int @default(10)

  pathway Pathway @relation(fields: [pathwayId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([pathwayId, courseId])
  @@unique([pathwayId, order]) // no duplicate order
  @@index([pathwayId])
}

model Content {
  id String @id @default(dbgenerated("gen_random_uuid()::text"))

  courseId String
  title    String
  type     ContentType
  value    String // text OR URL (SharePoint link, video, etc.)
  duration Int?   // video length in seconds (used for SharePoint progress tracking)

  order Int

  course            Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  contentProgresses ContentProgress[]
  comments          Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@unique([courseId, order])
}

enum ContentType {
  TEXT
  LINK
  VIDEO
}

model Test {
  id       String @id @default(dbgenerated("gen_random_uuid()::text"))
  courseId String @unique

  passThreshold Int // percentage (e.g., 70)

  questions Question[]

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model Question {
  id String @id @default(dbgenerated("gen_random_uuid()::text"))

  testId   String
  type     QuestionType
  question String

  order Int

  test    Test             @relation(fields: [testId], references: [id], onDelete: Cascade)
  options QuestionOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@unique([testId, order])
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  FILL_BLANK
  RANKING
  MATCHING
}

model QuestionOption {
  id String @id @default(dbgenerated("gen_random_uuid()::text"))

  questionId String
  text       String
  isCorrect  Boolean?

  // for ranking / matching flexibility
  matchKey String?
  order    Int?

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// ── Assignment ─────────────────────────────────────────────────────────────────

model Assignment {
  id          String  @id @default(dbgenerated("gen_random_uuid()::text"))
  courseId    String  @unique
  description String
  submitUrl   String  // SharePoint link where users upload their file

  course      Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model AssignmentSubmission {
  id           String           @id @default(dbgenerated("gen_random_uuid()::text"))
  assignmentId String
  userId       String
  pathwayId    String

  submissionUrl String
  grade         Float?
  status        SubmissionStatus @default(SUBMITTED)
  adminNote     String?

  gradedAt   DateTime?
  gradedById String?

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])
  pathway    Pathway    @relation(fields: [pathwayId], references: [id])
  gradedBy   User?      @relation("AssignmentGrader", fields: [gradedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignmentId, status])
  @@index([userId, pathwayId])
}

enum SubmissionStatus {
  SUBMITTED
  PASSED
  FAILED
}

model PathwayEnrollment {
  id String @id @default(dbgenerated("gen_random_uuid()::text"))

  userId    String
  pathwayId String
  cohortId  String?

  type   EnrollmentType
  status EnrollmentStatus

  deadline DateTime?

  requestedById String?
  approvedById  String?

  note            String?
  rejectionReason String?

  user      User    @relation(fields: [userId], references: [id])
  cohort    Cohort? @relation(fields: [cohortId], references: [id])
  requester User?   @relation("Requester", fields: [requestedById], references: [id])
  approver  User?   @relation("Approver", fields: [approvedById], references: [id])
  pathway   Pathway @relation(fields: [pathwayId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, pathwayId])
  @@index([userId, status])
  @@index([pathwayId, status])
  @@index([cohortId])
}

enum EnrollmentType {
  SELF_ENROLL
  ASSIGNED
  USER_REQUEST
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

model CourseProgress {
  id String @id @default(dbgenerated("gen_random_uuid()::text"))

  userId    String
  courseId  String
  pathwayId String

  completed        Boolean     @default(false)
  testScore        Float?
  testStatus       TestStatus?
  assignmentStatus TestStatus?

  completedAt DateTime?

  user    User    @relation(fields: [userId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id])
  pathway Pathway @relation(fields: [pathwayId], references: [id])

  @@unique([userId, courseId, pathwayId])
  @@index([userId, pathwayId])
  @@index([pathwayId, completed])
}

enum TestStatus {
  PASSED
  FAILED
}

model ContentProgress {
  id String @id @default(dbgenerated("gen_random_uuid()::text"))

  userId    String
  contentId String
  pathwayId String

  completedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  content Content @relation(fields: [contentId], references: [id])
  pathway Pathway @relation(fields: [pathwayId], references: [id])

  @@unique([userId, contentId, pathwayId])
  @@index([userId, pathwayId])
  @@index([pathwayId])
}

model UserPoint {
  id String @id @default(dbgenerated("gen_random_uuid()::text"))

  userId      String
  points      Int
  source      PointSource
  referenceId String?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
}

enum PointSource {
  COURSE_COMPLETION
}

model Comment {
  id            String   @id @default(dbgenerated("gen_random_uuid()::text"))
  contentId     String
  pathwayId     String
  userId        String
  parentId      String?
  replyToUserId String?
  body          String

  user        User     @relation("CommentAuthor", fields: [userId], references: [id])
  replyToUser User?    @relation("CommentReplyTo", fields: [replyToUserId], references: [id])
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  pathway     Pathway  @relation(fields: [pathwayId], references: [id], onDelete: Cascade)
  parent      Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentReplies")
  notifications Notification[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([contentId, pathwayId])
  @@index([parentId])
}

enum NotificationType {
  COMMENT_REPLY
  ENROLLMENT_APPROVED
  ENROLLMENT_REJECTED
  PATHWAY_ASSIGNED
  COHORT_PATHWAY_ASSIGNED
  ASSIGNMENT_GRADED
  ASSIGNMENT_SUBMITTED
  GROWTH_PLAN_COMPLETED
  GROWTH_PLAN_CONFIRMED
}

model Notification {
  id            String           @id @default(dbgenerated("gen_random_uuid()::text"))
  userId        String
  type          NotificationType
  message       String
  commentId     String?
  pathwayId     String?
  relatedUserId String?
  read          Boolean          @default(false)

  user    User     @relation(fields: [userId], references: [id])
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)
  pathway Pathway? @relation(fields: [pathwayId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, read])
}

model GrowthPlan {
  id            String    @id @default(dbgenerated("gen_random_uuid()::text"))
  userId        String
  pathwayId     String?
  title         String
  completedAt   DateTime?
  confirmedAt   DateTime?
  confirmedById String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  pathway     Pathway? @relation(fields: [pathwayId], references: [id])
  confirmedBy User?    @relation("GrowthPlanConfirmer", fields: [confirmedById], references: [id])
}

